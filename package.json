{
  "name": "fluent-api",
  "type": "module",
  "version": "1.0.0",
  "license": "MIT",
  "engines": {
    "node": ">=24.14.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:worker": "tsx watch src/workers/standalone-worker.ts",
    "start": "node ./dist/src/index.js",
    "worker": "node ./dist/src/workers/standalone-worker.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "cross-env NODE_ENV=test vitest",
    "build": "tsc && tsc-alias",
    "build:webjob": "npm run build && node scripts/setup-webjob.js",
    "deploy:prepare": "npm run build:webjob && cd wwwroot && zip -r ../deploy.zip . && cd ..",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "precheck": "npm run lint && npm run format:check && npm run typecheck && npm run test",
    "db:seed:rbac": "npx tsx src/db/seeds/rbac.ts",
    "db:migrate": "drizzle-kit migrate",
    "db:generate": "drizzle-kit generate --name",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@hono/node-server": "1.19.13",
    "@hono/zod-openapi": "0.19.10",
    "@scalar/hono-api-reference": "0.9.12",
    "applicationinsights": "3.14.0",
    "archiver": "7.0.1",
    "auth0": "4.28.0",
    "dotenv": "16.6.1",
    "dotenv-expand": "12.0.2",
    "drizzle-orm": "0.45.2",
    "drizzle-zod": "0.7.1",
    "hono": "4.12.14",
    "hono-pino": "0.8.0",
    "jose": "5.10.0",
    "jwks-rsa": "3.2.0",
    "mailgun.js": "12.0.3",
    "pg-boss": "12.1.1",
    "pino": "9.7.0",
    "postgres": "3.4.7",
    "stoker": "1.4.2",
    "usfm-grammar": "3.2.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@antfu/eslint-config": "4.18.0",
    "@types/archiver": "6.0.3",
    "@types/node": "24.1.0",
    "cross-env": "7.0.3",
    "drizzle-kit": "0.31.10",
    "eslint": "9.31.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-format": "1.0.1",
    "husky": "9.1.7",
    "pino-pretty": "13.0.0",
    "prettier": "3.6.2",
    "tsc-alias": "1.8.16",
    "tsx": "4.21.0",
    "typescript": "5.8.3",
    "vitest": "3.2.4"
  }
}
